# Dependencies
node_modules/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Auth state (generated by global-setup.ts)
# session.json にはブラウザの Cookie・sessionStorage が含まれるためコミットしない
/.auth/

# Performance measurement output (generated at runtime)
# 計測データは管理対象外
/output/*

# ただし、サンプルデータだけは例外としてGitに含める
!/output/perf-log-sample.json
!/output/perf-summary-sample.csv
!/output/evidence_sample.xlsx

# Environment Variables
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*.log

# Scripts
scripts/.venv/

# Python
__pycache__/
*.pyc
*.pyo
